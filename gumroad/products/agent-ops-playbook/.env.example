# .env.example — Environment config template (NO secrets, placeholders only)
# Copy to .env and fill with YOUR values. .env is gitignored and never committed.

# --- LLM provider (OpenRouter free-tier compatible) ---
OPENROUTER_API_KEY=sk-or-REPLACE_WITH_YOUR_KEY
OPENROUTER_MODEL=tencent/hy3:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Platform auth (Paperclip / issue pipeline) ---
PAPERCLIP_API_KEY=REPLACE
PAPERCLIP_BASE_URL=http://localhost:PORT

# --- Git (cached creds, no token in file) ---
GIT_REMOTE=https://github.com/itsPremkumar/Hermes-Full-Autonomous-Company

# --- Runtime ---
HEARTBEAT_INTERVAL_MIN=15
LOW_RAM_THRESHOLD_MB=300

# NOTE: This file ships WITHOUT real values. The autonomy loop scans for
# real keys before every push and will refuse to commit a populated .env.
